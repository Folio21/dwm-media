# Copy this file to .env and fill in real values. Never commit .env.

# Google Places API (New) key — Text Search + Place Details must be enabled
GOOGLE_PLACES_API_KEY=

# Anthropic API key — reused from Jarvis, needed starting Phase 2 (Demo Site Builder)
ANTHROPIC_API_KEY=

# Unsplash API Access Key (free) — adds real stock photos to generated demo sites.
# Optional: if left blank, demo sites just skip images instead of failing.
UNSPLASH_ACCESS_KEY=

# Server port
PORT=4000
